function safeParse(s: string): { ok: true; value: any } | { ok: false; error: string } {
  try {
    const v = JSON.parse(s);
    if (!v || typeof v !== "object") return { ok: false, error: "JSON must be an object." };
    return { ok: true, value: v };
  } catch (e: any) {
    return { ok: false, error: e?.message ?? "Invalid JSON" };
  }
}

function normalizeShowInput(v: any): ShowQuoteInput {
  const input = v ?? {};
  const req = input.requirements ?? {};
  const cost = input.cost_inputs_sar ?? {};
  const manual = input.manual_override ?? {};
  const event = input.event ?? {};

  return {
    quote_id: input.quote_id ?? "Q-LOCAL-000",
    version: typeof input.version === "number" ? input.version : 1,

    event: {
      client_name: event.client_name ?? "Client",
      event_name: event.event_name ?? "Drone Light Show",
      city_type: event.city_type ?? "URBAN",
      show_date: event.show_date ?? new Date().toISOString().slice(0, 10),
    },

    requirements: {
      required_drones: typeof req.required_drones === "number" ? req.required_drones : 1000,
      duration_min: typeof req.duration_min === "number" ? req.duration_min : 12,
      prep_days: req.prep_days ?? undefined,
      permits_days_remaining: typeof req.permits_days_remaining === "number" ? req.permits_days_remaining : 0,
      risk_level: req.risk_level ?? "MED",
    },

    cost_inputs_sar: {
      variable_base: cost.variable_base ?? 0,
      transport: cost.transport ?? 0,
      crew: cost.crew ?? 0,
      site_ops: cost.site_ops ?? 0,
      other: cost.other ?? 0,
    },

    manual_override: {
      enabled: !!manual.enabled,
      notes: manual.notes ?? "",
    },

    proposed_price_ex_vat_sar:
      typeof input.proposed_price_ex_vat_sar === "number" ? input.proposed_price_ex_vat_sar : undefined,
  };
}

function money(n: any) {
  const x = Number(n);
  if (!Number.isFinite(x)) return String(n ?? "");
  return x.toLocaleString(undefined, { maximumFractionDigits: 2 });
}

function ownerForGap(category: any) {
  switch (category) {
    case "PERMITS_LEAD_TIME": return "Compliance / Permits";
    case "DRONES_AVAILABILITY": return "Ops / Fleet";
    case "SPARE_RATIO": return "Ops / Fleet";
    case "CHARGING_CAPACITY": return "Ops / Logistics";
    case "GROUND_RTK": return "Tech / Field";
    case "GROUND_AP": return "Tech / Field";
    default: return "Ops";
  }
}

function priorityForGap(g: any) {
  const sev = Number(g?.severity ?? 0);
  if (g?.blocker && sev >= 60) return "P0";
  if (g?.blocker) return "P1";
  if (sev >= 40) return "P2";
  return "P3";
}

function dueDaysForGap(g: any) {
  const ltr = Number(g?.lead_time_risk ?? 3); // 1..5
  const base = (6 - Math.max(1, Math.min(5, ltr))) * 3; // 15..3
  const adj = g?.blocker ? -2 : 0;
  return Math.max(1, base + adj);
}

function toTSV(rows: any[]) {
  const header = ["#", "Gap", "Owner", "Priority", "DueDays", "Fix", "Blocker", "Value"];
  const lines = [header.join("\t")];
  rows.forEach((r, i) => {
    lines.push([
      String(i + 1),
      String(r.gap ?? ""),
      String(r.owner ?? ""),
      String(r.priority ?? ""),
      String(r.due_days ?? ""),
      String(r.fix ?? ""),
      String(r.blocker ?? ""),
      String(r.value ?? ""),
    ].join("\t"));
  });
  return lines.join("\n");
}

